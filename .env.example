# Platform upload (Wardrive → multipart POST)
VITE_UPLOAD_URL=https://api.example.com/v1/wardrive/upload
VITE_DEVICE_SOURCE=pwnterrey_marauder

# Login: POST { username, password } — response may be { access, refresh } or { tokens: { access, refresh } }
# Register: POST { username, email, password, password_confirm } — response { user, tokens: { access, refresh } }
VITE_LOGIN_URL=http://localhost:8000/wardriving/auth/login
VITE_REGISTER_URL=http://localhost:8000/wardriving/auth/register
